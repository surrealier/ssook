# ssook environment variables — copy to .env and edit.
# All keys are optional; defaults preserve current behaviour.

# Network
SSOOK_PORT=8765

# Logging — settings/logs/ssook.log (10 MiB × 5 rotation)
SSOOK_LOG_LEVEL=INFO
SSOOK_LOG_DIR=settings/logs

# Heartbeat watchdog: if the client stops sending /api/heartbeat for this many
# seconds, the server shuts itself down. Set high (e.g. 86400) when debugging.
SSOOK_HEARTBEAT_TIMEOUT=120

# Path-safety: extra allowlist roots for safe_path's optional `roots=` checks.
# Comma-separated absolute paths. Most routes don't enforce a root list today;
# this is plumbing for future LAN-exposed deployments.
SSOOK_EXTRA_ROOTS=

# VLM (v1.1+): override the BLIP tokenizer location if/when BLIP backends ship.
# Unused by the v1 CLIP-only backend.
SSOOK_BLIP_TOKENIZER=

# Cache directory for embedding/feature caches (currently advisory).
SSOOK_CACHE_DIR=settings/cache
